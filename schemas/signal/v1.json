{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://bitcoin-intel/schemas/signal/v1.json",
  "title": "Signal",
  "type": "object",
  "required": [
    "id",
    "date",
    "signal",
    "tension",
    "macro_implication",
    "narrative_role",
    "cluster",
    "theme",
    "weight",
    "dir",
    "horizon",
    "cat",
    "catLabel",
    "source"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(STR|SUP|INF|MAC|NAR)-\\d{4}-\\d{4}-\\d{3}$",
      "readOnly": true,
      "description": "Уникальный идентификатор. Формат: PREFIX-YYYY-MMDD-NNN"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Дата события (не добавления)"
    },
    "signal": {
      "type": "string",
      "minLength": 20,
      "maxLength": 300,
      "description": "Заголовок сигнала — факт без интерпретации"
    },
    "tension": {
      "type": "string",
      "minLength": 30,
      "pattern": "^[А-ЯA-Z0-9]",
      "description": "Начинается с заглавной или цифры (напр. '80% транзакций...' — легитимный статистический зачин, найден в production INF-2026-0622-001). Содержит vs/несмотря на/при условии"
    },
    "macro_implication": {
      "type": "string",
      "minLength": 40,
      "description": "Структурный вывод — что изменилось для Bitcoin"
    },
    "narrative_role": {
      "type": "string",
      "oneOf": [
        {
          "const": "trigger",
          "description": "Первый сигнал нового кластера или резкий перелом"
        },
        {
          "const": "complication",
          "description": "Добавляет противоречие в существующий нарратив"
        },
        {
          "const": "resolution",
          "description": "Закрывает tension предыдущих сигналов"
        },
        {
          "const": "background",
          "description": "Структурный контекст без острого события"
        }
      ]
    },
    "cluster": {
      "type": "string",
      "description": "Должен существовать в ontology.clusters"
    },
    "theme": {
      "type": "string",
      "oneOf": [
        {
          "const": "supply",
          "description": "Дефицит, эмиссия, потерянные монеты"
        },
        {
          "const": "institutionalization",
          "description": "ETF, корпорации, правительства, владение"
        },
        {
          "const": "infrastructure",
          "description": "Lightning, Layer 2, майнинг"
        },
        {
          "const": "macro",
          "description": "Ставки, ликвидность, макро-давление"
        },
        {
          "const": "narrative",
          "description": "Философия, регуляция, нарративы"
        }
      ]
    },
    "weight": {
      "type": "string",
      "oneOf": [
        {
          "const": "onchain",
          "description": "верифицируемые данные блокчейна"
        },
        {
          "const": "primary",
          "description": "первичный источник (высказывание, документ)"
        },
        {
          "const": "market",
          "description": "биржевые данные, цена, объёмы"
        },
        {
          "const": "media",
          "description": "медиа, аналитики, оценки"
        }
      ]
    },
    "dir": {
      "type": "string",
      "oneOf": [
        {
          "const": "pos",
          "description": "усиливает позицию BTC"
        },
        {
          "const": "neg",
          "description": "создаёт давление на BTC"
        },
        {
          "const": "neu",
          "description": "структурный факт без направления"
        }
      ]
    },
    "horizon": {
      "type": "string",
      "oneOf": [
        {
          "const": "short",
          "description": "недели–месяцы"
        },
        {
          "const": "mid",
          "description": "месяцы–год"
        },
        {
          "const": "long",
          "description": "годы, структурные изменения"
        }
      ]
    },
    "cat": {
      "type": "string",
      "oneOf": [
        {
          "const": "onchain",
          "description": "ON-CHAIN — например: Production Cost, MVRV, NVT"
        },
        {
          "const": "ta",
          "description": "Технический анализ — депрецирована в v6.0, новые сигналы с этой категорией не создаются"
        },
        {
          "const": "macro",
          "description": "МАКРО — например: Ставки, ликвидность, DXY"
        },
        {
          "const": "mining",
          "description": "МАЙНИНГ — например: Хешрейт, сложность, капитуляция"
        },
        {
          "const": "narrative",
          "description": "НАРРАТИВ — например: Регуляция, институционалы, события"
        },
        {
          "const": "layer2",
          "description": "LAYER 2 — например: Stacks, Lightning, сайдчейны"
        },
        {
          "const": "ownership",
          "description": "ВЛАДЕНИЕ — например: Распределение по типам владельцев"
        }
      ]
    },
    "catLabel": {
      "type": "string",
      "description": "Human-readable метка категории с emoji"
    },
    "source": {
      "type": "string",
      "minLength": 5,
      "description": "Название источника и месяц/год"
    },
    "data": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "context": {
      "type": "string"
    },
    "caveat": {
      "type": "string"
    },
    "actor": {
      "type": "string",
      "oneOf": [
        {
          "const": "etf",
          "description": "биржевые фонды (BlackRock, Fidelity)"
        },
        {
          "const": "corporate",
          "description": "публичные компании (Strategy, MSTR)"
        },
        {
          "const": "government",
          "description": "государственные резервы"
        },
        {
          "const": "defi",
          "description": "протоколы, on-chain структуры"
        },
        {
          "const": "retail",
          "description": "розничные инвесторы"
        },
        {
          "const": "miner",
          "description": "майнеры"
        }
      ]
    },
    "flow": {
      "type": "string",
      "oneOf": [
        {
          "const": "inflow",
          "description": "капитал входит в BTC"
        },
        {
          "const": "outflow",
          "description": "капитал уходит из BTC"
        },
        {
          "const": "internal",
          "description": "перераспределение внутри структуры"
        },
        {
          "const": "neutral",
          "description": "движения капитала нет или неизвестно"
        }
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Уверенность аналитика в интерпретации"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "links": {
      "type": "object",
      "description": "DEPRECATED — переносится в relationships.json (Фаза 0 завершена, IRP v1 B2)",
      "properties": {
        "confirms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contradicts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "context_chain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "cluster_label": {
      "type": [
        "string",
        "null"
      ],
      "description": "НЕДОКУМЕНТИРОВАНО в CLAUDE.md/ADDENDUM §17.1 исходно — встречается в 2 существующих сигналах (production-данные, не в спеке). Схема разрешает поле явно, а не через additionalProperties, чтобы Contract Tests не падали на реальных данных, пока не принято решение оставить/убрать (IRP v1 Wave 3, документационный follow-up)."
    },
    "theory_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "НЕДОКУМЕНТИРОВАНО в CLAUDE.md/ADDENDUM §17.1 исходно — встречается в 1 существующем сигнале (production-данные, не в спеке). См. cluster_label выше — тот же follow-up."
    },
    "alternatives_considered": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Требуется CLAUDE.md v7.7 Шаг 3/7 (≥1 содержательная отклонённая альтернатива с причиной). Отсутствовало в схеме до её обновления при добавлении первого сигнала с этим полем — INF-2026-0702-001."
    },
    "alternative_scenario": {
      "type": [
        "string",
        "null"
      ],
      "description": "Требуется CLAUDE.md v7.7 Шаг 3/7 когда уверенность в интерпретации не высокая (ADR-015). Отсутствовало в схеме до её обновления при добавлении первого сигнала с этим полем — INF-2026-0702-001."
    },
    "facts": {
      "type": "array",
      "description": "Опционально. Структурированные машиночитаемые факты из этого сигнала — дополняют свободнотекстовый data, не заменяют его. Ключ key: 'entity_id.metric' (entity_id переиспользует ENTITIES.json.id где применимо; для агрегатных категорий без сущности — любой стабильный snake_case идентификатор). Обрабатывается scripts/build_facts.py → data/facts.json (см. CLAUDE.md, раздел 'FACTS — машиночитаемые факты'). Добавлено CLAUDE.md v8.2.",
      "items": {
        "type": "object",
        "required": [
          "key",
          "value",
          "unit",
          "as_of"
        ],
        "additionalProperties": false,
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+$",
            "description": "Формат 'entity_id.metric', оба сегмента — snake_case"
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "as_of": {
            "type": "string",
            "format": "date",
            "description": "Дата, на которую значение верно (не дата сигнала обязательно — может быть точнее)"
          }
        }
      }
    }
  }
}
